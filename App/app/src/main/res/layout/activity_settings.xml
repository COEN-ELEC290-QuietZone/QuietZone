<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SettingsActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/my_toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="0dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:titleTextColor="@color/app_on_primary"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:padding="0dp"
        app:layout_constraintTop_toBottomOf="@id/my_toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/profileHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="0dp">

                <ImageView
                    android:id="@+id/profileAvatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/app_primary"
                    android:contentDescription="@string/profile_avatar_desc" />

                <TextView
                    android:id="@+id/profileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/profile_name"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/jost"
                    android:textColor="@color/app_on_background" />

            </LinearLayout>

            <GridLayout
                android:id="@+id/settingsGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:padding="0dp"
                android:columnCount="1"
                android:alignmentMode="alignMargins"
                android:useDefaultMargins="false">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_margin="8dp"
                    android:text="Support Info"
                    android:textColor="@color/app_on_background"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/jost"
                    app:icon="@drawable/ic_info"
                    app:iconGravity="top"
                    app:iconTint="@color/app_on_background"
                    app:iconSize="64dp"
                    app:iconPadding="0dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button2"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_margin="8dp"
                    android:text="Theme"
                    android:textColor="@color/app_on_background"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/jost"
                    app:icon="@drawable/ic_brightness"
                    app:iconGravity="top"
                    app:iconTint="@color/app_on_background"
                    app:iconSize="64dp"
                    app:iconPadding="2dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button3"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_margin="8dp"
                    android:text="Notifications"
                    android:textColor="@color/app_on_background"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/jost"
                    app:icon="@drawable/ic_notifications"
                    app:iconGravity="top"
                    app:iconTint="@color/app_on_background"
                    app:iconSize="64dp"
                    app:iconPadding="2dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button4"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_margin="8dp"
                    android:text="Privacy"
                    android:textColor="@color/app_on_background"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/jost"
                    app:icon="@drawable/ic_lock"
                    app:iconGravity="top"
                    app:iconTint="@color/app_on_background"
                    app:iconSize="64dp"
                    app:iconPadding="2dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button5"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_margin="8dp"
                    android:text="My Account"
                    android:textColor="@color/app_on_background"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/jost"
                    app:icon="@drawable/ic_person"
                    app:iconGravity="top"
                    app:iconTint="@color/app_on_background"
                    app:iconSize="64dp"
                    app:iconPadding="2dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button6"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_margin="8dp"
                    android:text="Help"
                    android:textColor="@color/app_on_background"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/jost"
                    app:icon="@drawable/ic_help"
                    app:iconGravity="top"
                    app:iconTint="@color/app_on_background"
                    app:iconSize="64dp"
                    app:iconPadding="2dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button7"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_margin="8dp"
                    android:text="Threshold"
                    android:textColor="@color/app_on_background"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/jost"
                    app:icon="@drawable/ic_tune"
                    app:iconGravity="top"
                    app:iconTint="@color/app_on_background"
                    app:iconSize="64dp"
                    app:iconPadding="2dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button8"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_margin="8dp"
                    android:text="Language"
                    android:textColor="@color/app_on_background"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/jost"
                    app:icon="@drawable/ic_language"
                    app:iconGravity="top"
                    app:iconTint="@color/app_on_background"
                    app:iconSize="64dp"
                    app:iconPadding="2dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button9"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_margin="8dp"
                    android:text="Rooms"
                    android:textColor="@color/app_on_background"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/jost"
                    app:icon="@drawable/ic_meeting_room"
                    app:iconGravity="top"
                    app:iconTint="@color/app_on_background"
                    app:iconSize="64dp"
                    app:iconPadding="2dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button10"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_margin="8dp"
                    android:text="Log Out"
                    android:textColor="@color/app_on_background"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/jost"
                    app:icon="@drawable/ic_logout"
                    app:iconGravity="top"
                    app:iconTint="@color/app_on_background"
                    app:iconSize="64dp"
                    app:iconPadding="2dp"
                    app:cornerRadius="16dp" />

            </GridLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>